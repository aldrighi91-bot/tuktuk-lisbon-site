{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/tours/:tour.html",
      "destination": "/tours/:tour",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|svg|webp|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
